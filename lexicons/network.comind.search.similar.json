{
  "lexicon": 1,
  "id": "network.comind.search.similar",
  "defs": {
    "main": {
      "type": "query",
      "description": "Find records semantically similar to a given record.",
      "parameters": {
        "type": "params",
        "required": ["uri"],
        "properties": {
          "uri": {
            "type": "string",
            "description": "AT Protocol URI of the source record"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 5
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["source", "results"],
          "properties": {
            "source": {"type": "ref", "ref": "network.comind.search.query#searchResult"},
            "results": {
              "type": "array",
              "items": {"type": "ref", "ref": "network.comind.search.query#searchResult"}
            }
          }
        }
      }
    }
  }
}
